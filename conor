<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Приглашение на свадьбу | Александр и Мария</title>
    <style>
        /* БАЗОВЫЕ НАСТРОЙКИ И МИНИМАЛИСТИЧНЫЙ СТИЛЬ */
        :root {
            --bg-color: #f7f5f0; /* Оттенок матовой светлой керамики */
            --text-color: #2c2a29; /* Глубокий оттенок темного дерева */
            --accent-color: #6b6e5b; /* Приглушенный природный зеленый/шалфей */
            --border-color: #e3dec9;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Helvetica Neue', Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        h1, h2, h3 {
            font-weight: 400;
            text-align: center;
            letter-spacing: 1.5px;
        }

        /* ГЛАВНЫЙ БЛОК */
        .hero {
            text-align: center;
            padding: 60px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .hero span {
            display: block;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 20px;
            color: var(--accent-color);
        }

        .hero h1 {
            font-size: 2.5rem;
            margin-bottom: 20px;
            font-family: 'Georgia', serif; /* Более элегантный шрифт для имен */
            font-style: italic;
        }

        .hero .date {
            font-size: 1.2rem;
            margin-top: 30px;
        }

        /* БЛОК ДЕТАЛЕЙ */
        .details {
            padding: 60px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .details h2 {
            font-size: 1.5rem;
            margin-bottom: 40px;
            text-transform: uppercase;
        }

        .detail-item {
            text-align: center;
            margin-bottom: 30px;
        }

        .detail-item h3 {
            font-size: 1.1rem;
            margin-bottom: 10px;
            color: var(--accent-color);
        }

        .detail-item p {
            font-size: 1rem;
        }

        /* ФОРМА ПОДТВЕРЖДЕНИЯ (RSVP) */
        .rsvp {
            padding: 60px 0 20px;
        }

        .rsvp h2 {
            font-size: 1.5rem;
            margin-bottom: 20px;
            text-transform: uppercase;
        }

        .rsvp p.subtitle {
            text-align: center;
            margin-bottom: 40px;
            font-size: 0.95rem;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        label {
            font-size: 0.9rem;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        input[type="text"],
        textarea {
            width: 100%;
            padding: 15px;
            border: 1px solid var(--border-color);
            background-color: transparent;
            font-family: inherit;
            font-size: 1rem;
            color: var(--text-color);
            transition: border-color 0.3s ease;
        }

        input[type="text"]:focus,
        textarea:focus {
            outline: none;
            border-color: var(--accent-color);
        }

        .radio-group {
            display: flex;
            gap: 20px;
            margin-top: 10px;
        }

        .radio-label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 400;
            text-transform: none;
            letter-spacing: 0;
            cursor: pointer;
        }

        button {
            margin-top: 20px;
            padding: 18px;
            background-color: var(--text-color);
            color: var(--bg-color);
            border: none;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: background-color 0.3s ease;
        }

        button:hover {
            background-color: var(--accent-color);
        }
    </style>
</head>
<body>

    <div class="container">
        <section class="hero">
            <span>Мы женимся</span>
            <h1>Александр & Мария</h1>
            <p>Приглашаем вас разделить с нами этот особенный день</p>
            <p class="date">15 Августа 2026</p>
        </section>

        <section class="details">
            <h2>План дня</h2>
            
            <div class="detail-item">
                <h3>Сбор гостей</h3>
                <p>15:00</p>
                <p>Ресторан "Лофт", ул. Примерная, 12</p>
            </div>
            
            <div class="detail-item">
                <h3>Церемония</h3>
                <p>16:00</p>
                <p>Летняя веранда ресторана</p>
            </div>

            <div class="detail-item">
                <h3>Праздничный ужин</h3>
                <p>17:30</p>
                <p>Основной зал</p>
            </div>
        </section>

        <section class="rsvp">
            <h2>Присутствие</h2>
            <p class="subtitle">Пожалуйста, подтвердите ваше присутствие до 1 августа</p>
            
            <form action="#" method="POST" id="rsvpForm">
                <div class="form-group">
                    <label for="name">Ваши Имя и Фамилия</label>
                    <input type="text" id="name" name="name" placeholder="Иван Иванов" required>
                </div>

                <div class="form-group">
                    <label>Сможете ли вы прийти?</label>
                    <div class="radio-group">
                        <label class="radio-label">
                            <input type="radio" name="attendance" value="yes" required> Да, с удовольствием!
                        </label>
                        <label class="radio-label">
                            <input type="radio" name="attendance" value="no"> К сожалению, не смогу
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label for="diet">Особые пожелания по еде / Аллергии</label>
                    <textarea id="diet" name="diet" rows="3" placeholder="(необязательно)"></textarea>
                </div>

                <button type="submit">Отправить ответ</button>
            </form>
        </section>
    </div>
<script>
    document.getElementById('rsvpForm').addEventListener('submit', function(e) {
        e.preventDefault(); // Отменяем стандартную перезагрузку страницы при отправке формы

        // Настройки Telegram
        const TOKEN = '8746093019:AAGSvsWsIKMZuwjf5qr8pcP6gl7wOD6VGMc'; 
        const CHAT_ID = '541982257';

        // Сбор данных из формы
        const name = document.getElementById('name').value;
        const attendanceElement = document.querySelector('input[name="attendance"]:checked');
        const attendance = attendanceElement && attendanceElement.value === 'yes' ? 'Да, с удовольствием!' : 'К сожалению, не смогу';
        const diet = document.getElementById('diet').value || 'Нет особых пожеланий';

        // Формирование текста сообщения
        const message = `🔔 Новый ответ на приглашение!\n\n` +
                        `👤 Гость: ${name}\n` +
                        `✅ Присутствие: ${attendance}\n` +
                        `🍽 Пожелания/Аллергии: ${diet}`;

        // URL для отправки запроса
        const url = `https://api.telegram.org/bot${TOKEN}/sendMessage`;

        // Замена кнопки на состояние загрузки
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalBtnText = submitBtn.innerText;
        submitBtn.innerText = 'Отправка...';
        submitBtn.disabled = true;

        // Отправка данных
        fetch(url, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                chat_id: CHAT_ID,
                text: message
            })
        })
        .then(response => {
            if(response.ok) {
                alert('Ваш ответ успешно отправлен!');
                document.getElementById('rsvpForm').reset();
            } else {
                alert('Произошла ошибка. Пожалуйста, попробуйте позже.');
            }
        })
        .catch(error => {
            console.error('Ошибка отправки:', error);
            alert('Произошла ошибка соединения.');
        })
        .finally(() => {
            // Возврат кнопки в исходное состояние
            submitBtn.innerText = originalBtnText;
            submitBtn.disabled = false;
        });
    });
</script>
</body>
</html>
